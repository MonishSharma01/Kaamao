# =============================================================================
# KAAMAO — Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local or real secrets to version control.
# See docs/ENVIRONMENT.md for full documentation on each variable.
# =============================================================================

# Supabase Project URL (found in: Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous/Public Key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key (SECRET — server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Direct Postgres connection string (used for migrations, NOT in runtime app code)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Supabase Publishable Key (optional, for new Supabase SDK features)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# PostHog Project API Key (also called Project Token)
# Used for frontend analytics tracking (pageviews, clicks, sessions, etc.)
# Get it from: PostHog Dashboard → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx

# --- Optional: Upstash Redis (for production rate limiting) ---
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# --- Optional: Sentry (for error tracking) ---
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
